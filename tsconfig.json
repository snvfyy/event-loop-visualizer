{
  "compilerOptions": {
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.js"],
  "exclude": [
    "node_modules",
    "src/preload.js",
    "src/vitest-environment.mjs",
    "src/transform.js"
  ]
}
